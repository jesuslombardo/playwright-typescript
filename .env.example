# ─────────────────────────────────────────────────────────────
# Environment variables template (documentation)
#
# These are the variables the framework reads via process.env.
#   - LOCAL: copy this file to ".env" and fill in your values.
#   - CI:    the same names are provided as GitHub Secrets
#            (see .github/workflows/ci.yml -> env:).
#
# ".env" is gitignored and must NEVER be committed.
# This ".env.example" has NO real secrets, so it is safe to commit.
#
# Sauce Demo uses PUBLIC demo credentials, so config/environments.ts
# already falls back to them — a real .env is only needed for private apps.
# ─────────────────────────────────────────────────────────────

SAUCE_STANDARD_USER=standard_user
SAUCE_STANDARD_PASSWORD=secret_sauce
