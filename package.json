{
  "name": "playwright-typescript",
  "version": "1.0.0",
  "description": "A foundational project to incrementally build a modern, maintainable, and scalable test automation framework, following real-world quality engineering practices.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:cross-browser": "CROSS_BROWSER=true playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:chromium": "playwright test --project=chromium",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep-invert @api",
    "test:visual": "playwright test tests/visual --project=chromium",
    "test:micro": "BASE_URL=http://localhost:3000 playwright test --project=api",
    "test:contract": "NO_WEBSERVER=1 playwright test --project=contract",
    "test:ai": "AI_TESTS=1 playwright test --project=ai",
    "test:patterns": "playwright test --config playwright.patterns.config.ts",
    "app:setup": "APP_VERSION=$(tr -d '[:space:]' < .app-version); rm -rf app && git clone --depth 1 --branch \"$APP_VERSION\" https://github.com/jesuslombardo/demo-shop-app app && npm --prefix app ci",
    "report": "playwright show-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jesuslombardo/playwright-typescript.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jesuslombardo/playwright-typescript/issues"
  },
  "homepage": "https://github.com/jesuslombardo/playwright-typescript#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@google/genai": "^2.9.0",
    "@pact-foundation/pact": "^16.5.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "ajv": "^8.20.0",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
