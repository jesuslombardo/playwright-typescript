{
  "consumer": {
    "name": "shop-web"
  },
  "interactions": [
    {
      "description": "a login with valid credentials",
      "providerStates": [
        {
          "name": "standard_user is a registered user"
        }
      ],
      "request": {
        "body": {
          "password": "secret_sauce",
          "username": "standard_user"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/login"
      },
      "response": {
        "body": {
          "token": "header.payload.signature",
          "username": "standard_user"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.username": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a login with invalid credentials",
      "request": {
        "body": {
          "password": "wrong",
          "username": "standard_user"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/api/login"
      },
      "response": {
        "body": {
          "error": "Username and password do not match any user in this service"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.error": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 401
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "auth-service"
  }
}
